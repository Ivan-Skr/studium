{% extends 'base.html' %}

{% block title %}Регистрация | Studium{% endblock %}

{% block content %}
<div class="min-h-[calc(100vh-80px)] flex items-center justify-center p-4">
    <div class="max-w-md w-full space-y-8">

        <div class="text-center">
            <div class="inline-flex items-center gap-2 mb-6 text-gray-900 dark:text-white">
                <svg class="w-8 h-8 text-blue-600 dark:text-blue-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                </svg>
                <span class="text-xl font-medium">Studium</span>
            </div>
            <h2 class="text-2xl font-bold mb-2">Регистрация</h2>
            <p class="text-gray-500 dark:text-slate-400">
                Создайте аккаунт для начала обучения
            </p>
        </div>

        <form method="post" action="{% url 'users:register' %}" class="bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-xl p-8 space-y-6 shadow-sm">
            {% csrf_token %}

            {% if form.non_field_errors or form.errors %}
                <div class="p-4 bg-red-50 dark:bg-red-950/30 border border-red-100 dark:border-red-900/50 rounded-lg">
                    {% for error in form.non_field_errors %}
                        <p class="text-sm text-red-600 dark:text-red-400">{{ error }}</p>
                    {% endfor %}
                    {% for field in form %}
                        {% for error in field.errors %}
                            <p class="text-sm text-red-600 dark:text-red-400">{{ field.label }}: {{ error }}</p>
                        {% endfor %}
                    {% endfor %}
                </div>
            {% endif %}

            <div>
                <label for="id_username" class="block mb-2 text-sm font-medium">Имя пользователя</label>
                <input
                    type="text"
                    name="username"
                    id="id_username"
                    value="{{ form.username.value|default_if_none:'' }}"
                    placeholder="ivan_ivanov"
                    class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800/50 rounded-lg border border-gray-200 dark:border-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-900/10 dark:focus:ring-slate-400/20 focus:border-slate-900 dark:focus:border-slate-500 text-gray-900 dark:text-white transition-all"
                    required
                />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="id_last_name" class="block mb-2 text-sm font-medium">Фамилия</label>
                    <input
                        type="text"
                        name="last_name"
                        id="id_last_name"
                        value="{{ form.last_name.value|default_if_none:'' }}"
                        placeholder="Иванов"
                        class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800/50 rounded-lg border border-gray-200 dark:border-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-900/10 dark:focus:ring-slate-400/20 focus:border-slate-900 dark:focus:border-slate-500 text-gray-900 dark:text-white transition-all"
                        required
                    />
                </div>
                <div>
                    <label for="id_first_name" class="block mb-2 text-sm font-medium">Имя</label>
                    <input
                        type="text"
                        name="first_name"
                        id="id_first_name"
                        value="{{ form.first_name.value|default_if_none:'' }}"
                        placeholder="Иван"
                        class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800/50 rounded-lg border border-gray-200 dark:border-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-900/10 dark:focus:ring-slate-400/20 focus:border-slate-900 dark:focus:border-slate-500 text-gray-900 dark:text-white transition-all"
                        required
                    />
                </div>
            </div>

            <div>
                <label for="id_email" class="block mb-2 text-sm font-medium">Email</label>
                <input
                    type="email"
                    name="email"
                    id="id_email"
                    value="{{ form.email.value|default_if_none:'' }}"
                    placeholder="your@email.com"
                    class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800/50 rounded-lg border border-gray-200 dark:border-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-900/10 dark:focus:ring-slate-400/20 focus:border-slate-900 dark:focus:border-slate-500 text-gray-900 dark:text-white transition-all"
                    required
                />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="id_password1" class="block mb-2 text-sm font-medium">Пароль</label>
                    <input
                        type="password"
                        name="password1"
                        id="id_password1"
                        placeholder="••••••••"
                        class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800/50 rounded-lg border border-gray-200 dark:border-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-900/10 dark:focus:ring-slate-400/20 focus:border-slate-900 dark:focus:border-slate-500 text-gray-900 dark:text-white transition-all"
                        required
                    />
                </div>
                <div>
                    <label for="id_password2" class="block mb-2 text-sm font-medium">Подтверждение</label>
                    <input
                        type="password"
                        name="password2"
                        id="id_password2"
                        placeholder="••••••••"
                        class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800/50 rounded-lg border border-gray-200 dark:border-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-900/10 dark:focus:ring-slate-400/20 focus:border-slate-900 dark:focus:border-slate-500 text-gray-900 dark:text-white transition-all"
                        required
                    />
                </div>
            </div>

            <div>
                <label class="block mb-2 text-sm font-medium">Роль</label>
                <div class="flex gap-4">
                    <label class="flex-1 flex items-center gap-3 p-4 border border-gray-200 dark:border-slate-700 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-slate-800/50 transition-colors has-[:checked]:border-slate-900 dark:has-[:checked]:border-slate-400 has-[:checked]:bg-gray-50 dark:has-[:checked]:bg-slate-800">
                        <input
                            type="radio"
                            name="role"
                            value="student"
                            {% if form.role.value == "student" or not form.role.value %}checked{% endif %}
