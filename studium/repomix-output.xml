<file path="users/templates/users/edit_profile.html">
{% extends "base.html" %}

{% block title %}Редактировать профиль | Studium{% endblock %}

{% block content %}
<div class="max-w-3xl mx-auto px-6 py-8">
  <a href="{% url 'users:profile' %}" class="inline-flex items-center gap-2 text-gray-500 dark:text-slate-400 hover:text-gray-900 dark:hover:text-white transition-colors mb-6 group">
    <i data-lucide="arrow-left" class="w-4 h-4"></i>
    Назад к профилю
  </a>

  <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm dark:bg-slate-800 dark:border-slate-700 transition-colors duration-200">
    <h2 class="text-2xl font-semibold mb-6 dark:text-white">Редактировать профиль</h2>

    {% if messages %}
      {% for message in messages %}
        <div class="mb-6 p-4 bg-green-50 dark:bg-green-950/30 border border-green-200 dark:border-green-900/50 rounded-lg">
          <p class="text-sm text-green-800 dark:text-green-400">{{ message }}</p>
        </div>
      {% endfor %}
    {% endif %}

    {% if form.errors %}
      <div class="mb-6 p-4 bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-900/30 rounded-lg">
        {% for field in form %}
          {% for error in field.errors %}
            <p class="text-sm text-red-600 dark:text-red-400">{{ field.label }}: {{ error }}</p>
          {% endfor %}
        {% endfor %}
        {% for error in form.non_field_errors %}
          <p class="text-sm text-red-600 dark:text-red-400">{{ error }}</p>
        {% endfor %}
      </div>
    {% endif %}

    <form method="post" enctype="multipart/form-data" class="space-y-6">
      {% csrf_token %}

      <div>
        <label for="id_username" class="block mb-2 font-medium dark:text-gray-200">Имя пользователя</label>
        <input
          id="id_username"
          name="username"
          type="text"
          value="{{ form.username.value|default_if_none:'' }}"
          placeholder="Ваше имя"
          class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900/50 rounded-lg border border-gray-300 dark:border-slate-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
          required
        />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="id_last_name" class="block mb-2 font-medium dark:text-gray-200">Фамилия</label>
          <input
            id="id_last_name"
            name="last_name"
            type="text"
            value="{{ form.last_name.value|default_if_none:'' }}"
            placeholder="Иванов"
            class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900/50 rounded-lg border border-gray-300 dark:border-slate-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
            required
          />
        </div>
        <div>
          <label for="id_first_name" class="block mb-2 font-medium dark:text-gray-200">Имя</label>
          <input
            id="id_first_name"
            name="first_name"
            type="text"
            value="{{ form.first_name.value|default_if_none:'' }}"
            placeholder="Иван"
            class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900/50 rounded-lg border border-gray-300 dark:border-slate-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
            required
          />
        </div>
      </div>

      <div>
        <label for="id_email" class="block mb-2 font-medium dark:text-gray-200">Email</label>
        <input
          id="id_email"
          name="email"
          type="email"
          value="{{ form.email.value|default_if_none:'' }}"
          placeholder="example@mail.com"
          class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900/50 rounded-lg border border-gray-300 dark:border-slate-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
          required
        />
      </div>

      <div>
        <label for="id_avatar" class="block mb-2 font-medium dark:text-gray-200">Аватар</label>
        {% if user.avatar %}
          <div class="mb-3 flex items-center gap-3">
            <div class="w-16 h-16 rounded-full overflow-hidden bg-gray-200 dark:bg-slate-700 border border-gray-200 dark:border-slate-600 transition-colors">
              <img src="{{ user.avatar.url }}" alt="Текущий аватар" class="w-full h-full object-cover" />
            </div>
            <span class="text-sm text-gray-500 dark:text-slate-400">Текущий аватар</span>
          </div>
        {% endif %}
        <input
          id="id_avatar"
          name="avatar"
          type="file"
          accept="image/*"
          class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900/50 rounded-lg border border-gray-300 dark:border-slate-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
        />
        <p class="text-xs text-gray-500 dark:text-slate-400 mt-1">Загрузите изображение для использования в качестве аватара.</p>
      </div>

      <div id="avatar-preview-container" class="hidden">
        <p class="text-sm text-gray-500 dark:text-slate-400 mb-2">Предпросмотр нового аватара</p>
        <div class="w-24 h-24 rounded-full overflow-hidden bg-gray-200 dark:bg-slate-700 border border-gray-200 dark:border-slate-600 transition-colors">
          <img
            id="avatar-preview-img"
            src=""
            alt="Avatar preview"
            class="w-full h-full object-cover"
          />
        </div>
      </div>

      <div class="flex gap-3 pt-4">
        <button
          type="submit"
          class="flex items-center gap-2 px-6 py-3 bg-blue-600 dark:bg-blue-500 text-white rounded-lg hover:bg-blue-700 dark:hover:bg-blue-600 transition-colors font-medium"
        >
          <i data-lucide="save" class="w-5 h-5"></i>
          <span>Сохранить изменения</span>
        </button>

        <a
          href="{% url 'users:profile' %}"
          class="px-6 py-3 border border-gray-300 dark:border-slate-700 rounded-lg hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors text-center text-gray-900 dark:text-gray-300"
        >
          Отмена
        </a>
      </div>
    </form>
  </div>
</div>

<script src="https://unpkg.com/lucide@latest"></script>
<script>
  lucide.createIcons();

  // Предпросмотр нового аватара из выбранного файла
  const avatarInput = document.getElementById('id_avatar');
  const previewContainer = document.getElementById('avatar-preview-container');
  const previewImg = document.getElementById('avatar-preview-img');

  avatarInput.addEventListener('change', (e) => {
    const file = e.target.files && e.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = (ev) => {
        previewImg.src = ev.target.result;
        previewContainer.classList.remove('hidden');
      };
      reader.readAsDataURL(file);
    } else {
      previewContainer.classList.add('hidden');
    }
  });
</script>
{% endblock %}
</file>

<file path="users/templates/users/login.html">
{% extends 'base.html' %}

{% block title %}Вход в аккаунт | Studium{% endblock %}

{% block content %}
<div class="min-h-[calc(100vh-80px)] flex items-center justify-center p-4">
    <div class="max-w-md w-full space-y-8">

        <div class="text-center">
            <div class="inline-flex items-center gap-2 mb-6 text-gray-900 dark:text-white">
                <svg class="w-8 h-8 text-blue-600 dark:text-blue-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                </svg>
                <span class="text-xl font-medium">Studium</span>
