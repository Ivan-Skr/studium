                        />
                        <span class="text-sm">Студент</span>
                    </label>
                    <label class="flex-1 flex items-center gap-3 p-4 border border-gray-200 dark:border-slate-700 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-slate-800/50 transition-colors has-[:checked]:border-slate-900 dark:has-[:checked]:border-slate-400 has-[:checked]:bg-gray-50 dark:has-[:checked]:bg-slate-800">
                        <input
                            type="radio"
                            name="role"
                            value="teacher"
                            {% if form.role.value == "teacher" %}checked{% endif %}
                            class="w-4 h-4 text-slate-900 dark:text-white focus:ring-slate-900 dark:focus:ring-slate-400 bg-transparent"
                        />
                        <span class="text-sm">Преподаватель</span>
                    </label>
                </div>
            </div>

            <button
                type="submit"
                class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-slate-900 dark:bg-slate-100 hover:bg-slate-800 dark:hover:bg-slate-200 text-white dark:text-slate-950 rounded-lg transition-colors font-medium"
            >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM4 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 0110.374 21c-2.331 0-4.512-.645-6.374-1.766z" />
                </svg>
                Зарегистрироваться
            </button>

            <div class="text-center text-sm">
                <span class="text-gray-500 dark:text-slate-400">Уже есть аккаунт? </span>
                <a href="{% url 'users:login' %}" class="text-slate-900 dark:text-white font-semibold hover:underline">
                    Войти
                </a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
