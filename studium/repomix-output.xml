<file path="users/templates/users/profile.html">
{% extends "base.html" %}

{% block title %}Профиль - Studium{% endblock %}

{% block content %}
<script src="https://unpkg.com/lucide@latest"></script>

<div class="max-w-5xl mx-auto px-6">

    <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-8 mb-8 shadow-sm transition-colors duration-200">
        <div class="flex flex-col md:flex-row items-start gap-6">
            <div class="w-24 h-24 rounded-full overflow-hidden bg-gray-100 dark:bg-slate-700 flex-shrink-0 transition-colors">
                {% if user.avatar %}
                    <img src="{{ user.avatar.url }}" alt="{{ user.username }}" class="w-full h-full object-cover" />
                {% else %}
                    <div class="w-full h-full flex items-center justify-center text-gray-400 dark:text-gray-500">
                        <i data-lucide="user" class="w-12 h-12"></i>
                    </div>
                {% endif %}
            </div>

            <div class="flex-1">
                <h1 class="text-2xl font-bold mb-1 dark:text-white">
                    {% if user.last_name or user.first_name %}{{ user.last_name }} {{ user.first_name }}{% else %}{{ user.username }}{% endif %}
                </h1>
                <p class="text-gray-600 dark:text-gray-400 text-sm mt-3 mb-1">@{{ user.username }}</p>
                <p class="text-gray-500 dark:text-gray-500 text-sm mb-3">{{ user.email }}</p>
                <div class="inline-block px-3 py-1 bg-gray-100 dark:bg-slate-700 text-gray-600 dark:text-gray-300 rounded-full text-sm font-medium transition-colors">
                    {{ user.role_display }}
                </div>
                {% if user.bio %}
                    <p class="mt-4 text-gray-700 dark:text-gray-300">{{ user.bio }}</p>
                {% endif %}
            </div>

            <div class="flex flex-col gap-2 w-full md:w-auto">
                <a href="{% url 'users:edit_profile' %}" class="flex items-center justify-center gap-2 px-4 py-2 border border-gray-200 dark:border-slate-600 rounded-lg hover:bg-gray-50 dark:hover:bg-slate-700 text-gray-900 dark:text-gray-200 transition-colors text-sm font-medium">
                    <i data-lucide="edit" class="w-4 h-4"></i>
                    Редактировать
                </a>
                <a href="{% url 'users:change_password' %}" class="flex items-center justify-center gap-2 px-4 py-2 border border-gray-200 dark:border-slate-600 rounded-lg hover:bg-gray-50 dark:hover:bg-slate-700 text-gray-900 dark:text-gray-200 transition-colors text-sm font-medium">
                    <i data-lucide="lock" class="w-4 h-4"></i>
                    Сменить пароль
                </a>
                <form action="{% url 'users:logout' %}" method="post" class="m-0">
                    {% csrf_token %}
                    <button type="submit" class="w-full flex items-center justify-center gap-2 px-4 py-2 border border-red-100 dark:border-red-900/50 text-red-600 dark:text-red-400 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/30 transition-colors text-sm font-medium">
                        <i data-lucide="log-out" class="w-4 h-4"></i>
                        Выйти
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 {% if user.is_teacher %}md:grid-cols-2{% else %}md:grid-cols-4{% endif %} gap-4 mb-8">
        <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 shadow-sm transition-colors duration-200">
            <div class="flex items-center gap-3 mb-2">
                <i data-lucide="book-open" class="w-5 h-5 text-gray-900 dark:text-gray-100"></i>
                <span class="text-gray-500 dark:text-gray-400 text-sm">Курсов</span>
            </div>
            <p class="text-2xl font-semibold dark:text-white">{% if user.is_teacher %}{{ user.courses_authored.count }}{% else %}{{ enrolled_courses_count }}{% endif %}</p>
        </div>

        {% if not user.is_teacher %}
        <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 shadow-sm transition-colors duration-200">
            <div class="flex items-center gap-3 mb-2">
                <i data-lucide="graduation-cap" class="w-5 h-5 text-gray-900 dark:text-gray-100"></i>
                <span class="text-gray-500 dark:text-gray-400 text-sm">Завершено</span>
            </div>
            <p class="text-2xl font-semibold dark:text-white">{{ completed_courses_count }}</p>
        </div>

        <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 shadow-sm transition-colors duration-200">
            <div class="flex items-center gap-3 mb-2">
                <i data-lucide="clock" class="w-5 h-5 text-gray-900 dark:text-gray-100"></i>
                <span class="text-gray-500 dark:text-gray-400 text-sm">Часов</span>
            </div>
            <p class="text-2xl font-semibold dark:text-white">{{ user.learning_hours_display }}</p>
        </div>
        {% endif %}

        <a href="{% url 'users:certificates' %}" class="block bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 shadow-sm hover:shadow-md transition-all duration-200">
            <div class="flex items-center gap-3 mb-2">
                <i data-lucide="award" class="w-5 h-5 text-gray-900 dark:text-gray-100"></i>
                <span class="text-gray-500 dark:text-gray-400 text-sm">Сертификатов</span>
            </div>
            <p class="text-2xl font-semibold dark:text-white">{% if user.is_teacher %}0{% else %}{{ certificates_count }}{% endif %}</p>
        </a>
    </div>

    <section>
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold dark:text-white">Мои курсы</h2>
            {% if user.is_teacher %}
            <a href="{% url 'lessons:teacher_course_list' %}" class="text-sm text-blue-600 dark:text-blue-400 hover:underline flex items-center gap-1">
                Управление курсами
                <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </a>
            {% endif %}
        </div>

        {% if user.is_teacher and authored_courses %}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {% for course in authored_courses %}
            <a href="{% url 'lessons:teacher_course_edit' course.pk %}"
               class="block bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-5 hover:border-blue-300 dark:hover:border-blue-500 hover:shadow-md transition-all group shadow-sm">
                <div class="flex items-start justify-between gap-2">
                    <p class="font-medium dark:text-gray-200 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">{{ course.name }}</p>
                    <i data-lucide="chevron-right" class="w-5 h-5 text-gray-400 group-hover:text-blue-600 dark:group-hover:text-blue-400 shrink-0"></i>
                </div>
                <div class="flex items-center gap-2 mt-3 text-sm text-gray-500 dark:text-gray-400">
                    {% if course.is_published %}
                        <span class="w-2 h-2 rounded-full bg-green-500"></span> Опубликован
                    {% else %}
                        <span class="w-2 h-2 rounded-full bg-gray-400 dark:bg-gray-500"></span> Черновик
                    {% endif %}
                </div>
            </a>
            {% endfor %}
        </div>
        {% elif user.is_teacher %}
        <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-8 text-center text-gray-500 dark:text-gray-400 shadow-sm flex flex-col items-center transition-colors">
            <i data-lucide="folder-open" class="w-10 h-10 text-gray-300 dark:text-slate-600 mb-3"></i>
            <p class="mb-4">У вас пока нет курсов.</p>
            <a href="{% url 'lessons:teacher_course_create' %}" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium">
                <i data-lucide="plus" class="w-4 h-4"></i>
                Создать курс
            </a>
        </div>
        {% elif enrolled_courses %}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {% for enrollment in enrolled_courses %}
            {% with course=enrollment.course %}
            <a href="{% url 'lessons:course_detail' course.pk %}"
               class="block bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-5 hover:border-blue-300 dark:hover:border-blue-500 hover:shadow-md transition-all group shadow-sm">
                <div class="flex items-start justify-between gap-2">
                    <p class="font-medium dark:text-gray-200 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">{{ course.name }}</p>
                    <i data-lucide="chevron-right" class="w-5 h-5 text-gray-400 group-hover:text-blue-600 dark:group-hover:text-blue-400 shrink-0"></i>
                </div>
                <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">
                    {{ course.author.get_full_name|default:course.author.username }}
                </p>
                {% if course.pk in completed_course_ids %}
                <span class="inline-block mt-3 px-2 py-0.5 text-xs bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 rounded">Курс пройден</span>
                {% endif %}
            </a>
            {% endwith %}
            {% endfor %}
        </div>
