    <h1 class="text-3xl font-bold mt-2 dark:text-white">{{ title }}</h1>
  </div>

  <form method="post" enctype="multipart/form-data" class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 space-y-5 shadow-sm transition-colors">
