</div>
{% endblock %}
</file>

<file path="lessons/templates/lessons/teaching/course_list.html">
{% extends "base.html" %}

{% block title %}Мои курсы — Studium{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-6">

  <div class="flex items-start justify-between gap-4 mb-8">
    <div>
      <h1 class="text-3xl font-bold mb-2 dark:text-white">Мои курсы</h1>
      <p class="text-gray-500 dark:text-gray-400">Управление курсами и аналитика</p>
    </div>
    <a href="{% url 'lessons:teacher_course_create' %}"
       class="inline-flex items-center gap-2 px-5 py-2.5 bg-slate-950 text-white rounded-xl hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:hover:bg-gray-200 font-semibold transition-colors">
      <span class="text-xl leading-none">+</span>
      Создать курс
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
    <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 shadow-sm">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">Всего курсов</p>
      <p class="text-4xl font-bold dark:text-white">{{ total_courses }}</p>
    </div>
    <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 shadow-sm">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">Студентов</p>
      <p class="text-4xl font-bold dark:text-white">{{ total_students }}</p>
      <p class="text-xs text-green-600 dark:text-green-400 mt-2">На всех курсах</p>
    </div>
    <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 shadow-sm">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">Средний прогресс</p>
      <p class="text-4xl font-bold dark:text-white">{{ average_progress }}%</p>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">По всем студентам</p>
    </div>
  </div>

  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-4">
    <h2 class="text-xl font-bold dark:text-white">Ваши курсы</h2>
    <form method="get" class="flex gap-3">
      <input type="search"
             name="q"
             value="{{ request.GET.q }}"
             placeholder="Поиск курсов..."
             class="w-full md:w-72 px-4 py-2.5 rounded-xl border border-gray-300 dark:border-slate-600 bg-gray-50 dark:bg-slate-800 dark:text-white focus:outline-none focus:ring-2 focus:ring-slate-900">
      <select name="status"
              class="px-4 py-2.5 rounded-xl border border-gray-300 dark:border-slate-600 bg-gray-50 dark:bg-slate-800 dark:text-white">
        <option value="">Все курсы</option>
        <option value="published" {% if request.GET.status == "published" %}selected{% endif %}>Опубликованные</option>
        <option value="draft" {% if request.GET.status == "draft" %}selected{% endif %}>Черновики</option>
      </select>
    </form>
  </div>

  <div class="space-y-5">
    {% for card in course_cards %}
      {% with course=card.course %}
      <article class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 shadow-sm">
        <div class="flex flex-col lg:flex-row gap-6">
          {% if course.image %}
            <img src="{{ course.image.url }}"
                 alt="{{ course.name }}"
                 class="w-full lg:w-48 h-28 object-cover rounded-xl bg-gray-100 dark:bg-slate-900">
          {% else %}
            <div class="w-full lg:w-48 h-28 rounded-xl bg-gray-100 dark:bg-slate-900"></div>
          {% endif %}

          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-4 mb-2">
              <div>
                <h3 class="text-lg font-bold dark:text-white">{{ course.name }}</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{{ course.description }}</p>
              </div>

              <div class="flex items-center gap-2 shrink-0">
                {% if course.is_published %}
                  <a href="{% url 'lessons:course_detail' course.pk %}"
                     class="w-9 h-9 inline-flex items-center justify-center rounded-lg border border-gray-200 dark:border-slate-600 hover:bg-gray-50 dark:hover:bg-slate-700"
                     title="Просмотр">👁</a>
                {% endif %}
                <a href="{% url 'lessons:teacher_course_edit' course.pk %}"
                   class="w-9 h-9 inline-flex items-center justify-center rounded-lg border border-gray-200 dark:border-slate-600 hover:bg-gray-50 dark:hover:bg-slate-700"
                   title="Редактировать">✎</a>
              </div>
            </div>

            <div class="border-t border-gray-100 dark:border-slate-700 mt-4 pt-4 grid grid-cols-2 md:grid-cols-4 gap-4">
              <div>
                <p class="text-sm text-gray-500 dark:text-gray-400">Студентов</p>
                <p class="text-xl font-bold dark:text-white">{{ card.students_count }}</p>
              </div>
              <div>
                <p class="text-sm text-gray-500 dark:text-gray-400">Уроков</p>
                <p class="text-xl font-bold dark:text-white">{{ card.lessons_count }}</p>
              </div>
              <div>
                <p class="text-sm text-gray-500 dark:text-gray-400">Продолжительность</p>
                <p class="text-xl font-bold dark:text-white">{{ card.duration_label }}</p>
              </div>
              <div>
                <p class="text-sm text-gray-500 dark:text-gray-400">Средний прогресс</p>
                <p class="text-xl font-bold dark:text-white">{{ card.average_progress }}%</p>
              </div>
            </div>

            <a href="{% url 'lessons:teacher_course_list' %}?students={{ course.pk }}"
               class="mt-4 w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-slate-950 text-white dark:bg-white dark:text-slate-950 rounded-xl font-semibold hover:opacity-90 transition-opacity">
              👥 Посмотреть студентов ({{ card.students_count }})
            </a>
          </div>
        </div>
      </article>
      {% endwith %}
    {% empty %}
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-12 text-center">
        <p class="text-gray-500 dark:text-gray-400 mb-4">Вы еще не создали ни одного курса.</p>
        <a href="{% url 'lessons:teacher_course_create' %}"
           class="inline-block px-5 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
          Создать первый курс
        </a>
      </div>
    {% endfor %}
  </div>
</div>

{% if active_modal %}
<div class="fixed inset-0 z-[100] bg-black/40 flex items-start justify-center overflow-auto">
  <div class="bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 w-full min-h-screen md:min-h-0 md:my-8 md:max-w-6xl md:rounded-xl shadow-xl overflow-hidden">
    {% if active_modal == "students" %}
      {% include "lessons/teaching/modals/students_modal.html" %}
    {% elif active_modal == "groups" %}
      {% include "lessons/teaching/modals/groups_modal.html" %}
    {% elif active_modal == "progress" %}
      {% include "lessons/teaching/modals/progress_modal.html" %}
    {% endif %}
  </div>
</div>
{% endif %}
{% endblock %}
</file>

<file path="lessons/templates/lessons/teaching/lesson_editor.html">
{% extends "base.html" %}

{% block title %}{{ lesson.name }} — {{ course.name }}{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto px-6">

  <div class="mb-6">
    <a href="{% url 'lessons:teacher_course_edit' course.pk %}" class="text-sm text-gray-500 hover:text-gray-400 transition-colors">
      ← {{ course.name }}
    </a>
    <h1 class="text-2xl font-bold mt-2 dark:text-white">Редактор урока</h1>
  </div>

  <section class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 shadow-sm mb-8 transition-colors duration-200">
    <form method="post" class="grid grid-cols-1 md:grid-cols-2 gap-4 items-end">
      {% csrf_token %}

      {% for field in lesson_form %}
        <div class="w-full">
          <label for="{% firstof field.id_for_label %}" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            {% firstof field.label %}
          </label>

          {% firstof field %}

          {% if field.help_text %}
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
              {% firstof field.help_text %}
            </p>
          {% endif %}

          {% for error in field.errors %}
            <p class="mt-1 text-sm text-red-600 dark:text-red-400">
              {% firstof error %}
            </p>
          {% endfor %}
        </div>
      {% endfor %}

      <div>
        <button type="submit" class="w-full px-4 py-2.5 bg-gray-900 dark:bg-slate-700 text-white dark:text-gray-100 rounded-lg hover:bg-gray-800 dark:hover:bg-slate-600 text-sm font-medium shrink-0 transition-colors">
          Сохранить урок
        </button>
      </div>
    </form>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-semibold mb-4 dark:text-white">Блоки урока</h2>

    {% if blocks %}
    <div class="space-y-3 mb-6">
      {% for item in blocks %}
      {% with block=item.block %}
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-4 shadow-sm transition-colors duration-200">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <span class="inline-block px-2 py-0.5 text-xs font-medium bg-blue-50 dark:bg-blue-950/50 text-blue-700 dark:text-blue-300 rounded mb-2">
              {{ item.type_label }} #{{ block.order }}
            </span>
            {% include "lessons/teaching/_block_preview.html" with block=block only %}
          </div>
          <div class="flex flex-wrap items-center gap-2 shrink-0">
            <form method="post" action="{% url 'lessons:teacher_block_move' course.pk lesson.pk block.pk 'up' %}">
              {% csrf_token %}
              <button type="submit" class="px-2 py-1 text-xs border border-gray-200 dark:border-slate-600 rounded text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors" title="Выше">↑</button>
            </form>
            <form method="post" action="{% url 'lessons:teacher_block_move' course.pk lesson.pk block.pk 'down' %}">
              {% csrf_token %}
              <button type="submit" class="px-2 py-1 text-xs border border-gray-200 dark:border-slate-600 rounded text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors" title="Ниже">↓</button>
            </form>
            <a href="{% url 'lessons:teacher_block_edit' course.pk lesson.pk block.pk %}"
               class="px-3 py-1.5 text-sm border border-gray-200 dark:border-slate-600 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
              Изменить
            </a>
            <form method="post" action="{% url 'lessons:teacher_block_delete' course.pk lesson.pk block.pk %}"
                  onsubmit="return confirm('Удалить этот блок?');">
              {% csrf_token %}
              <button type="submit" class="px-3 py-1.5 text-sm text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 transition-colors">Удалить</button>
            </form>
          </div>
        </div>
      </div>
      {% endwith %}
      {% endfor %}
    </div>
    {% else %}
    <p class="text-gray-500 dark:text-gray-400 text-sm mb-6 text-center py-8 bg-white dark:bg-slate-800 border border-dashed border-gray-200 dark:border-slate-700 rounded-lg transition-colors">
      Блоков пока нет. Выберите тип блока ниже.
    </p>
    {% endif %}
  </section>

  <section>
    <h2 class="text-lg font-semibold mb-4 dark:text-white">Добавить блок</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      {% for slug, config in block_types.items %}
      <a href="{% url 'lessons:teacher_block_create' course.pk lesson.pk slug %}"
         class="block p-4 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg hover:border-blue-300 dark:hover:border-blue-500 hover:shadow-sm dark:hover:bg-slate-750 transition-all text-center group">
        <p class="font-medium text-sm mb-1 dark:text-gray-200 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">{{ config.label }}</p>
        <p class="text-xs text-gray-500 dark:text-gray-400">{{ config.description }}</p>
      </a>
      {% endfor %}
    </div>
  </section>

  <div class="mt-8 pt-6 border-t border-gray-200 dark:border-slate-700">
    <a href="{% url 'lessons:lesson_detail' course.pk lesson.pk %}"
       class="text-sm text-blue-600 dark:text-blue-400 hover:underline inline-flex items-center gap-1" target="_blank" rel="noopener">
      Предпросмотр урока →
    </a>
  </div>

</div>
{% endblock %}
</file>

<file path="lessons/templates/lessons/teaching/lesson_form.html">
{% extends "base.html" %}

{% block title %}{{ title }} — {{ course.name }}{% endblock %}

