    <article class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-5 shadow-sm">
      {% if certificate.image %}
      <img src="{{ certificate.image.url }}" alt="{{ certificate.title }}" class="w-full max-h-48 object-contain rounded bg-gray-50 dark:bg-slate-900 mb-4">
