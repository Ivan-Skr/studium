def get_block_type_slug(block):
    for slug, config in BLOCK_TYPES.items():
        if isinstance(block, config["model"]):
            return slug
    return None


def get_block_type_label(block):
    slug = get_block_type_slug(block)
    if slug:
        return BLOCK_TYPES[slug]["label"]
    return "Блок"
