                    required
                />
            </div>

            <div>
                <label for="id_password" class="block mb-2 text-sm font-medium">Пароль</label>
                <input
                    type="password"
                    name="password"
                    id="id_password"
                    placeholder="••••••••"
                    class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800/50 rounded-lg border border-gray-200 dark:border-slate-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                    required
                />
            </div>

            <input type="hidden" name="next" value="{{ next }}">

            <button
                type="submit"
                class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-blue-600 dark:bg-blue-500 hover:bg-blue-700 dark:hover:bg-blue-600 text-white rounded-lg transition-colors font-medium"
            >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
                </svg>
                <span>Войти</span>
            </button>

            <div class="text-center text-sm">
                <span class="text-gray-500 dark:text-slate-400">Нет аккаунта? </span>
                <a href="{% url 'users:register' %}" class="text-blue-600 dark:text-blue-400 hover:underline font-medium">
                    Зарегистрироваться
                </a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
