      <h2 class="text-xl font-bold dark:text-white">
        {% firstof calendar_grid.month_label %}
      </h2>
      <div class="text-sm text-gray-500 dark:text-gray-400">
        Всего дедлайнов: {% firstof events|length 0 %}
      </div>
