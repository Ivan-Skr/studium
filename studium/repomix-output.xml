<file path="lessons/templates/lessons/teaching/block_form.html">
{% extends "base.html" %}

{% block title %}{% if is_edit %}Редактирование{% else %}Добавление{% endif %}: {{ block_label }} — Studium{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto px-6">

  <div class="mb-6">
    <a href="{% url 'lessons:teacher_lesson_editor' course.pk lesson.pk %}"
       class="text-sm text-gray-500 hover:text-gray-400 transition-colors">
      ← {{ lesson.name }}
    </a>
    <h1 class="text-2xl font-bold mt-2 dark:text-white">
      {% if is_edit %}Редактирование{% else %}Добавление{% endif %}: {{ block_label }}
    </h1>
  </div>

  <form method="post" enctype="multipart/form-data"
        class="bg-white border border-gray-200 dark:bg-slate-800 dark:border-slate-700 rounded-lg p-6 space-y-5 shadow-sm transition-colors duration-200">
    {% csrf_token %}

    {% for field in form %}
    <div>
      <label for="{{ field.id_for_label }}" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
        {{ field.label }}
      </label>

      {# Переопределение базовых стилей для встроенных виджетов Django form #}
      <div class="[&_input[type='text']]:w-full [&_input[type='text']]:px-4 [&_input[type='text']]:py-2.5 [&_input[type='text']]:rounded-lg [&_input[type='text']]:border [&_input[type='text']]:border-gray-300 [&_input[type='text']]:bg-white [&_input[type='text']]:text-gray-900 [&_input[type='text']]:focus:ring-2 [&_input[type='text']]:focus:ring-blue-500 [&_input[type='text']]:dark:border-slate-600 [&_input[type='text']]:dark:bg-slate-700 [&_input[type='text']]:dark:text-white [&_input[type='text']]:dark:focus:ring-blue-500
                  [&_textarea]:w-full [&_textarea]:px-4 [&_textarea]:py-2.5 [&_textarea]:rounded-lg [&_textarea]:border [&_textarea]:border-gray-300 [&_textarea]:bg-white [&_textarea]:text-gray-900 [&_textarea]:focus:ring-2 [&_textarea]:focus:ring-blue-500 [&_textarea]:dark:border-slate-600 [&_textarea]:dark:bg-slate-700 [&_textarea]:dark:text-white [&_textarea]:dark:focus:ring-blue-500
                  [&_input[type='file']]:block [&_input[type='file']]:w-full [&_input[type='file']]:text-sm [&_input[type='file']]:text-gray-500 [&_input[type='file']]:dark:text-gray-400 [&_input[type='file']]:file:mr-4 [&_input[type='file']]:file:py-2 [&_input[type='file']]:file:px-4 [&_input[type='file']]:file:rounded-md [&_input[type='file']]:file:border-0 [&_input[type='file']]:file:text-sm [&_input[type='file']]:file:font-semibold [&_input[type='file']]:file:bg-blue-50 [&_input[type='file']]:file:text-blue-700 [&_input[type='file']]:hover:file:bg-blue-100 [&_input[type='file']]:dark:file:bg-slate-700 [&_input[type='file']]:dark:file:text-gray-200
                  [&_input[type='number']]:w-full [&_input[type='number']]:px-4 [&_input[type='number']]:py-2.5 [&_input[type='number']]:rounded-lg [&_input[type='number']]:border [&_input[type='number']]:border-gray-300 [&_input[type='number']]:bg-white [&_input[type='number']]:text-gray-900 [&_input[type='number']]:dark:border-slate-600 [&_input[type='number']]:dark:bg-slate-700 [&_input[type='number']]:dark:text-white">
        {{ field }}
      </div>

      {% if field.help_text %}
      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">{{ field.help_text }}</p>
      {% endif %}
      {% for error in field.errors %}
      <p class="mt-1 text-sm text-red-600 dark:text-red-400">{{ error }}</p>
      {% endfor %}
      {% if is_edit %}
        {% if field.name == "image" or field.name == "video" or field.name == "audio" or field.name == "teachers_file" %}
      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Оставьте пустым, чтобы не менять файл.</p>
        {% endif %}
      {% endif %}
    </div>
    {% endfor %}

    {% if formset %}
    <div class="pt-4 border-t border-gray-200 dark:border-slate-700" id="choice-answers-section">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold dark:text-white">Варианты ответа</h3>
        <button type="button" id="add-answer-btn"
                class="text-sm px-3 py-1.5 border border-gray-200 dark:border-slate-600 rounded-lg hover:bg-gray-50 dark:hover:bg-slate-700 dark:text-gray-200 transition-colors">
          + Добавить вариант
        </button>
      </div>
      {{ formset.management_form }}
      {% if formset.non_form_errors %}
      <div class="mb-3 p-3 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-lg text-sm text-red-700 dark:text-red-400">
        {% for error in formset.non_form_errors %}{{ error }}{% endfor %}
      </div>
      {% endif %}
      <div id="answer-forms-list" class="space-y-3">
        {% for answer_form in formset %}
        <div class="answer-form-row flex flex-wrap items-start gap-3 p-3 bg-gray-50 dark:bg-slate-700/50 rounded-lg">
          {% for hidden in answer_form.hidden_fields %}{{ hidden }}{% endfor %}
          <div class="flex-1 min-w-[200px] [&_input]:w-full [&_input]:px-3 [&_input]:py-1.5 [&_input]:rounded-md [&_input]:border [&_input]:border-gray-300 [&_input]:bg-white [&_input]:text-gray-900 [&_input]:dark:border-slate-600 [&_input]:dark:bg-slate-700 [&_input]:dark:text-white">
            {{ answer_form.text }}
            {% for error in answer_form.text.errors %}
            <p class="mt-1 text-xs text-red-600 dark:text-red-400">{{ error }}</p>
            {% endfor %}
          </div>
          <label class="flex items-center gap-2 text-sm shrink-0 pt-2 dark:text-gray-200 cursor-pointer">
            {{ answer_form.is_correct }}
            <span>Верный</span>
          </label>
          {% if answer_form.DELETE %}
          <label class="flex items-center gap-1 text-sm text-red-600 dark:text-red-400 shrink-0 pt-2 cursor-pointer">
            {{ answer_form.DELETE }}
            <span>Удалить</span>
          </label>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>

    <template id="empty-answer-form-template">
      <div class="answer-form-row flex flex-wrap items-start gap-3 p-3 bg-gray-50 dark:bg-slate-700/50 rounded-lg">
        {% for hidden in formset.empty_form.hidden_fields %}{{ hidden }}{% endfor %}
        <div class="flex-1 min-w-[200px] [&_input]:w-full [&_input]:px-3 [&_input]:py-1.5 [&_input]:rounded-md [&_input]:border [&_input]:border-gray-300 [&_input]:bg-white [&_input]:text-gray-900 [&_input]:dark:border-slate-600 [&_input]:dark:bg-slate-700 [&_input]:dark:text-white">
          {{ formset.empty_form.text }}
        </div>
        <label class="flex items-center gap-2 text-sm shrink-0 pt-2 dark:text-gray-200 cursor-pointer">
          {{ formset.empty_form.is_correct }}
          <span>Верный</span>
        </label>
      </div>
    </template>

    <script>
    (function () {
      const addBtn = document.getElementById("add-answer-btn");
      const list = document.getElementById("answer-forms-list");
      const template = document.getElementById("empty-answer-form-template");
      const totalInput = document.getElementById("id_answers-TOTAL_FORMS");
      if (!addBtn || !list || !template || !totalInput) return;

      addBtn.addEventListener("click", function () {
        const index = parseInt(totalInput.value, 10);
        const wrapper = document.createElement("div");
        wrapper.innerHTML = template.innerHTML.replace(/__prefix__/g, index);
        const row = wrapper.firstElementChild;
        list.appendChild(row);
        totalInput.value = index + 1;
        const textInput = row.querySelector('input[type="text"]');
        if (textInput) textInput.focus();
      });
    })();
    </script>
    {% endif %}

    <div class="flex gap-3 pt-2">
      <button type="submit" class="px-5 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 dark:bg-blue-600 dark:hover:bg-blue-500 font-medium transition-colors">
        {% if is_edit %}Сохранить{% else %}Добавить блок{% endif %}
      </button>
      <a href="{% url 'lessons:teacher_lesson_editor' course.pk lesson.pk %}"
         class="px-5 py-2.5 border border-gray-200 dark:border-slate-600 text-gray-900 dark:text-gray-200 rounded-lg hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
        Отмена
      </a>
    </div>
  </form>

</div>
{% endblock %}
</file>

<file path="lessons/templates/lessons/teaching/course_edit.html">
{% extends "base.html" %}

{% block title %}Редактирование: {{ course.name }} - Studium{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto px-6">

  <div class="mb-6">
    <a href="{% url 'lessons:teacher_course_list' %}" class="text-sm text-gray-500 hover:text-gray-400 transition-colors">Назад к курсам</a>
    <h1 class="text-3xl font-bold mt-2 dark:text-white">{{ course.name }}</h1>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <section class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 shadow-sm transition-colors duration-200">
      <h2 class="text-lg font-semibold mb-4 dark:text-white">Настройки курса</h2>

      <form method="post" enctype="multipart/form-data" class="space-y-5">
        {% csrf_token %}
        {% include "lessons/teaching/_course_form_fields.html" %}

        {% if course.image %}
        <p class="text-xs text-gray-500 dark:text-gray-400">Текущая обложка сохранена. Загрузите новый файл, чтобы заменить.</p>
        {% endif %}
        {% if course.detail_image %}
        <p class="text-xs text-gray-500 dark:text-gray-400">Фото для страницы курса сохранено. Загрузите новый файл, чтобы заменить.</p>
        {% endif %}

        <div class="flex flex-wrap gap-3 pt-2">
          <button type="submit" class="px-5 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium transition-colors">
            Сохранить
          </button>
          {% if course.is_published %}
          <a href="{% url 'lessons:course_detail' course.pk %}" class="px-5 py-2.5 border border-gray-200 dark:border-slate-600 text-gray-700 dark:text-gray-200 rounded-lg hover:bg-gray-50 dark:hover:bg-slate-700 font-medium transition-colors">
            Просмотр
          </a>
          {% endif %}
        </div>
      </form>

      <form method="post" action="{% url 'lessons:teacher_course_delete' course.pk %}"
            class="mt-6 pt-6 border-t border-gray-200 dark:border-slate-700"
            onsubmit="return confirm('Удалить курс «{{ course.name|escapejs }}»? Это действие нельзя отменить.');">
        {% csrf_token %}
        <button type="submit" class="text-sm text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 font-medium transition-colors">
          Удалить курс
        </button>
      </form>
    </section>

    <section class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 shadow-sm transition-colors duration-200">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold dark:text-white">Уроки</h2>
        <a href="{% url 'lessons:teacher_lesson_create' course.pk %}"
           class="text-sm px-3 py-1.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium transition-colors">
          Добавить
        </a>
      </div>

      {% if lessons %}
      <ul class="space-y-2">
        {% for lesson in lessons %}
        <li class="flex items-center justify-between gap-3 p-3 border border-gray-100 dark:border-slate-700/50 rounded-lg bg-gray-50/50 dark:bg-slate-900/30">
          <span class="text-sm text-gray-400 dark:text-gray-500 font-mono w-6">{{ lesson.order }}</span>
          <span class="flex-1 font-medium dark:text-gray-200">{{ lesson.name }}</span>
          <div class="flex gap-2 shrink-0 items-center">
            <form method="post" action="{% url 'lessons:teacher_lesson_move' course.pk lesson.pk 'up' %}">
              {% csrf_token %}
              <button type="submit" class="px-2 py-1 text-xs border border-gray-200 dark:border-slate-600 rounded text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">↑</button>
            </form>
            <form method="post" action="{% url 'lessons:teacher_lesson_move' course.pk lesson.pk 'down' %}">
              {% csrf_token %}
              <button type="submit" class="px-2 py-1 text-xs border border-gray-200 dark:border-slate-600 rounded text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">↓</button>
            </form>
            <a href="{% url 'lessons:teacher_lesson_editor' course.pk lesson.pk %}"
               class="text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium transition-colors">Редактировать</a>
            <form method="post" action="{% url 'lessons:teacher_lesson_delete' course.pk lesson.pk %}"
                  onsubmit="return confirm('Удалить урок «{{ lesson.name|escapejs }}»?');">
              {% csrf_token %}
              <button type="submit" class="text-sm text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 transition-colors">Удалить</button>
            </form>
          </div>
        </li>
        {% endfor %}
      </ul>
      {% else %}
      <p class="text-gray-500 dark:text-gray-400 text-sm text-center py-6">Уроков пока нет. Добавьте первый урок.</p>
      {% endif %}
    </section>
  </div>

  <section class="mt-8 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 shadow-sm transition-colors duration-200">
    <h2 class="text-lg font-semibold mb-4 dark:text-white">Сертификаты</h2>

    <form method="post" enctype="multipart/form-data" action="{% url 'lessons:teacher_certificate_create' course.pk %}" class="space-y-4 border border-gray-100 dark:border-slate-700 rounded-lg p-4 mb-6">
      {% csrf_token %}
      <h3 class="font-medium dark:text-white">Создать сертификат</h3>
      {% include "lessons/teaching/_course_form_fields.html" with form=certificate_form %}
      <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">Создать</button>
    </form>

    {% for card in certificate_cards %}
      {% with certificate=card.template selected_ids=card.selected_student_ids edit_form=card.form %}
      {% if certificate.is_completion_certificate %}
      <details class="border border-blue-200 dark:border-blue-900/60 rounded-lg p-4 mb-4 bg-blue-50/40 dark:bg-blue-900/10">
      {% else %}
      <details class="border border-gray-200 dark:border-slate-700 rounded-lg p-4 mb-4">
      {% endif %}
        <summary class="cursor-pointer list-none">
          <div class="flex items-center gap-4">
            {% if certificate.image %}
            <img src="{{ certificate.image.url }}" alt="{{ certificate.title }}" class="w-24 h-16 object-contain bg-gray-50 dark:bg-slate-900 rounded border border-gray-100 dark:border-slate-700">
            {% endif %}
            <div class="flex-1">
              <h3 class="font-semibold dark:text-white">{{ certificate.title }}</h3>
              {% if certificate.is_completion_certificate %}
              <p class="text-sm text-blue-700 dark:text-blue-400">Выдается автоматически за прохождение курса</p>
              {% endif %}
              {% if certificate.description %}
              <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{{ certificate.description }}</p>
              {% endif %}
            </div>
          </div>
        </summary>

        <div class="mt-5 grid grid-cols-1 lg:grid-cols-2 gap-6">
          <form method="post" enctype="multipart/form-data" action="{% url 'lessons:teacher_certificate_update' course.pk certificate.pk %}" class="space-y-4">
            {% csrf_token %}
            {% include "lessons/teaching/_course_form_fields.html" with form=edit_form %}
            <div class="flex gap-2">
              <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">Сохранить</button>
            </div>
          </form>

          <div>
            {% if certificate.is_completion_certificate %}
            <div class="p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-900/50 rounded-lg text-sm text-blue-800 dark:text-blue-300">
              Этот сертификат выдается автоматически после прохождения всех уроков курса.
            </div>
            {% else %}
            <form method="post" action="{% url 'lessons:teacher_certificate_assign' course.pk certificate.pk %}" class="space-y-3">
              {% csrf_token %}
              <h4 class="font-medium dark:text-white">Выдать студентам</h4>
              {% if enrolled_students %}
              <div class="space-y-2 max-h-64 overflow-auto pr-2">
                {% for student in enrolled_students %}
                <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
                  <input type="checkbox" name="students" value="{{ student.pk }}" class="rounded border-gray-300 text-blue-600" {% if student.pk in selected_ids %}checked{% endif %}>
                  <span>{{ student.last_name }} {{ student.first_name }} · {{ student.email }} · {{ student.username }}</span>
                </label>
                {% endfor %}
              </div>
              <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">Сохранить выдачу</button>
              {% else %}
              <p class="text-sm text-gray-500 dark:text-gray-400">На курс пока никто не записан.</p>
              {% endif %}
            </form>
            {% endif %}

            <form method="post" action="{% url 'lessons:teacher_certificate_delete' course.pk certificate.pk %}" class="mt-4" onsubmit="return confirm('Удалить сертификат «{{ certificate.title|escapejs }}»? У студентов уже выданные сертификаты останутся.');">
              {% csrf_token %}
              <button type="submit" class="text-sm text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300">Удалить сертификат</button>
            </form>
          </div>
        </div>
      </details>
      {% endwith %}
    {% empty %}
      <p class="text-sm text-gray-500 dark:text-gray-400">Сертификатов пока нет.</p>
    {% endfor %}
  </section>

  {% if course.requires_enrollment_code %}
  <section class="mt-8 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6 shadow-sm transition-colors duration-200">
    <h2 class="text-lg font-semibold mb-4 dark:text-white">Заявки на запись</h2>

    {% if enrollment_requests %}
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-gray-500 dark:text-gray-400 border-b border-gray-200 dark:border-slate-700">
            <th class="py-2 pr-4 font-medium">Имя</th>
            <th class="py-2 pr-4 font-medium">Фамилия</th>
            <th class="py-2 pr-4 font-medium">Email</th>
            <th class="py-2 pr-4 font-medium">Username</th>
            <th class="py-2 font-medium"></th>
          </tr>
        </thead>
        <tbody>
          {% for enrollment in enrollment_requests %}
          <tr class="border-b border-gray-100 dark:border-slate-700/60">
            <td class="py-3 pr-4 dark:text-gray-200">{{ enrollment.student.first_name|default:"-" }}</td>
            <td class="py-3 pr-4 dark:text-gray-200">{{ enrollment.student.last_name|default:"-" }}</td>
            <td class="py-3 pr-4 dark:text-gray-200">{{ enrollment.student.email }}</td>
            <td class="py-3 pr-4 dark:text-gray-200">{{ enrollment.student.username }}</td>
            <td class="py-3">
              <div class="flex gap-2 justify-end">
                <form method="post" action="{% url 'lessons:teacher_enrollment_decide' course.pk enrollment.pk 'approve' %}">
                  {% csrf_token %}
                  <button type="submit" class="px-3 py-1.5 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">Одобрить</button>
                </form>
                <form method="post" action="{% url 'lessons:teacher_enrollment_decide' course.pk enrollment.pk 'reject' %}">
                  {% csrf_token %}
                  <button type="submit" class="px-3 py-1.5 border border-red-200 text-red-600 dark:border-red-900/60 dark:text-red-400 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">Отклонить</button>
                </form>
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% else %}
    <p class="text-sm text-gray-500 dark:text-gray-400">Новых заявок нет.</p>
    {% endif %}
  </section>
  {% endif %}

</div>
{% endblock %}
</file>

<file path="lessons/templates/lessons/teaching/course_form.html">
{% extends "base.html" %}

{% block title %}{{ title }} — Studium{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto px-6">

  <div class="mb-6">
