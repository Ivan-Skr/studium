        <form method="post" action="{% url 'users:login' %}" class="bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-xl p-8 space-y-6 shadow-sm">
            {% csrf_token %}

            {% if form.non_field_errors or form.errors %}
                <div class="p-4 bg-red-50 dark:bg-red-950/30 border border-red-200 dark:border-red-900/50 rounded-lg">
                    {% for error in form.non_field_errors %}
                        <p class="text-sm text-red-600 dark:text-red-400">{{ error }}</p>
                    {% endfor %}
                    {% for field in form %}
                        {% for error in field.errors %}
                            <p class="text-sm text-red-600 dark:text-red-400">{{ field.label }}: {{ error }}</p>
                        {% endfor %}
                    {% endfor %}
                </div>
            {% endif %}

            <div>
                <label for="id_username" class="block mb-2 text-sm font-medium">Email или имя пользователя</label>
                <input
                    type="text"
