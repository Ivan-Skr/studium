    <div class="grid grid-cols-7 border-b border-gray-200 dark:border-slate-700 bg-gray-100 dark:bg-slate-800">
      <div class="px-3 py-3 text-xs font-bold text-gray-500 dark:text-gray-400 uppercase text-center">Sun</div>
      <div class="px-3 py-3 text-xs font-bold text-gray-500 dark:text-gray-400 uppercase text-center">Mon</div>
      <div class="px-3 py-3 text-xs font-bold text-gray-500 dark:text-gray-400 uppercase text-center">Tue</div>
      <div class="px-3 py-3 text-xs font-bold text-gray-500 dark:text-gray-400 uppercase text-center">Wed</div>
